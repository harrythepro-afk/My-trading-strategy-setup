# Secure Binance API Keys Configuration Template
# Instructions:
# 1. Rename this file from '.env.example' to exactly '.env'
# 2. Paste your Binance Testnet (or Live Futures) keys below:

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# NOTE: Never upload your actual '.env' file to GitHub or share it publicly!
